<Window x:Class="PdfTitleRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDFタイトル一括リネーム"
        Width="1220"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        FontFamily="Yu Gothic UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#13213C" Padding="26,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="PDFタイトル一括リネーム"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,5,0,0"
                               Text="先頭2ページをOCRし、文字とレイアウトをCodexで判定します"
                               Foreground="#B9C7DF"
                               FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="CodexStatusBadge"
                            Background="#273B60"
                            CornerRadius="14"
                            Padding="12,6"
                            Margin="0,0,10,0">
                        <TextBlock x:Name="CodexStatusText"
                                   Text="Codex確認中…"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Button x:Name="LoginButton"
                            Content="ChatGPTにログイン"
                            Click="LoginButton_Click"
                            Padding="13,7" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="22,18,22,0"
                Padding="16"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Text="対象フォルダ"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}" />
                <TextBox x:Name="FolderTextBox"
                         Grid.Column="1"
                         Height="36"
                         Padding="10,7"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1"
                         Background="#F8FAFC"
                         Foreground="{StaticResource InkBrush}" />
                <Button Grid.Column="2"
                        Margin="10,0,0,0"
                        Content="フォルダを選択"
                        Click="ChooseFolderButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="22,12,22,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#E8F0FF" CornerRadius="6" Padding="10,6">
                    <TextBlock Foreground="#244A90" FontSize="12">
                        <Run Text="メタデータ・現在のファイル名はAI判定に使用しません。" />
                        <Run Text=" 結果は実行前に編集・選択できます。" />
                    </TextBlock>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="すべて選択" Padding="11,6" Margin="0,0,8,0" Click="SelectAllButton_Click" />
                <Button Content="選択解除" Padding="11,6" Click="ClearSelectionButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                Margin="22,0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">
            <DataGrid x:Name="PdfGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EDF1F7"
                      BorderThickness="0"
                      RowHeight="48"
                      ColumnHeaderHeight="40"
                      AlternatingRowBackground="#FAFCFF"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      EnableRowVirtualization="True">
                <DataGrid.Resources>
                    <Style TargetType="ToolTip">
                        <Setter Property="MaxWidth" Value="560" />
                        <Setter Property="Padding" Value="10,7" />
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               MaxWidth="540" />
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="EllipsisTextBlock" TargetType="TextBlock">
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="TextWrapping" Value="NoWrap" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
                        <Setter Property="ToolTipService.ShowDuration" Value="60000" />
                        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
                    </Style>
                    <Style x:Key="EditableFileNameTextBox" TargetType="TextBox">
                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
                        <Setter Property="ToolTipService.ShowDuration" Value="60000" />
                    </Style>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F7FB" />
                        <Setter Property="Foreground" Value="#4B5872" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="BorderBrush" Value="#E2E8F0" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="8,0" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="対象"
                                            Width="58"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="現在のファイル名"
                                        Width="2*"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource EllipsisTextBlock}"
                                        Binding="{Binding CurrentName}" />
                    <DataGridTextColumn Header="変更後のファイル名（編集可）"
                                        Width="2.4*"
                                        ElementStyle="{StaticResource EllipsisTextBlock}"
                                        EditingElementStyle="{StaticResource EditableFileNameTextBox}"
                                        Binding="{Binding SuggestedName, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="確信度"
                                        Width="75"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource EllipsisTextBlock}"
                                        Binding="{Binding ConfidenceDisplay}" />
                    <DataGridTextColumn Header="AIの判断根拠"
                                        Width="2.2*"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource EllipsisTextBlock}"
                                        Binding="{Binding Reason}" />
                    <DataGridTextColumn Header="状態"
                                        Width="105"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource EllipsisTextBlock}"
                                        Binding="{Binding Status}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4"
                Margin="22,14,22,20"
                Padding="16"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="OperationStatusText"
                               Text="フォルダを選択してください"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12" />
                    <ProgressBar x:Name="OperationProgress"
                                 Margin="0,8,18,0"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="#E8EDF5" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton"
                            Content="中止"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="CancelButton_Click" />
                    <Button x:Name="AnalyzeButton"
                            Content="OCR＋AIでタイトル推定"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="AnalyzeButton_Click" />
                    <Button x:Name="RenameButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="選択したPDFをリネーム"
                            IsEnabled="False"
                            Click="RenameButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
