<Window x:Class="PdfTitleRenamer.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="バージョン情報とライセンス"
        Width="900"
        Height="700"
        MinWidth="700"
        MinHeight="520"
        Icon="Icons/app.ico"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB"
        FontFamily="Yu Gothic UI"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,16"
                Margin="0,0,0,12"
                Background="#13213C"
                CornerRadius="9">
            <StackPanel>
                <TextBlock Text="PDF Title to Filename AI"
                           Foreground="White"
                           FontSize="23"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="VersionText"
                           Margin="0,5,0,0"
                           Text="Version"
                           Foreground="#B9C7DF"
                           FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">
            <TabControl BorderThickness="0" Background="Transparent" Margin="8">
                <TabItem Header="アプリ情報">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="22">
                            <TextBlock Text="PDFタイトル一括リネーム AI版"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock Margin="0,10,0,20"
                                       Text="PDFの先頭2ページをPDFiumで描画し、Windows OCRとCodexを使って正式タイトルを推定します。"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="14" />

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="125" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="バージョン" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="VersionDetailText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="1" Text="作者" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="fa-yoshinobu" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="2" Text="ライセンス" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="MIT License" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="3" Text="GitHub" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="3" Grid.Column="1">
                                    <Hyperlink NavigateUri="https://github.com/fa-yoshinobu/PDF_Title_to_Filename_AI"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        https://github.com/fa-yoshinobu/PDF_Title_to_Filename_AI
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>

                            <Border Padding="16"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <StackPanel>
                                    <TextBlock Text="ライセンスについて"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1E40AF" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="本ソフトウェア本体はMIT Licenseです。同梱するPDFium、PDFtoImage、SkiaSharpなどのライセンスと著作権表示は「第三者ライセンス」タブで確認できます。"
                                               TextWrapping="Wrap"
                                               LineHeight="21" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0"
                                    Padding="16"
                                    Background="#FFF4D6"
                                    BorderBrush="#E5A817"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <StackPanel>
                                    <TextBlock Text="AIへのデータ送信について"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#704A00" />
                                    <TextBlock x:Name="LicenseAiUploadWarningText"
                                               Margin="0,8,0,0"
                                               Text="AI解析を実行すると、PDF先頭2ページの画像とOCR結果がCodex経由でOpenAIへアップロードされます。機密情報・個人情報を含むPDFは、所属組織や利用中のサービスの規則を確認してから処理してください。"
                                               TextWrapping="Wrap"
                                               LineHeight="21"
                                               Foreground="#573A00" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="MITライセンス">
                    <Grid Margin="16">
                        <TextBox x:Name="AppLicenseTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Padding="14"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0" />
                    </Grid>
                </TabItem>

                <TabItem Header="第三者ライセンス">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Content="完全なライセンス文書を開く"
                                    Click="OpenThirdPartyLicensesButton_Click"
                                    Padding="12,7" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="同梱コンポーネントの概要と参照先"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />
                        </DockPanel>
                        <TextBox x:Name="ThirdPartyNoticesTextBox"
                                 Grid.Row="1"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Padding="14"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Button Grid.Row="2"
                Margin="0,12,0,0"
                Padding="24,8"
                HorizontalAlignment="Right"
                Content="閉じる"
                IsCancel="True" />
    </Grid>
</Window>
